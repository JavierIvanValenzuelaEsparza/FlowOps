# Service
SERVICE_NAME=flowops-ocr
SERVER_HOST=0.0.0.0
SERVER_PORT=8001

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_QUEUE=ocr_jobs
RABBITMQ_RESULT_QUEUE=ocr_results
RABBITMQ_PREFETCH=1
RABBITMQ_HEARTBEAT=600
RABBITMQ_RECONNECT_DELAY=5

# MinIO
MINIO_HOST=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=flowops-documents
MINIO_SECURE=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
CACHE_TTL_SECONDS=86400

# OCR
OCR_LANGUAGE=spa+eng
OCR_DPI=200
MAX_RETRIES=3

# Logging
LOG_LEVEL=INFO

# Application
APP_NAME=FlowOps API
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# MongoDB
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DATABASE=flowops
MONGO_USERNAME=
MONGO_PASSWORD=
MONGO_REPLICA_SET=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# MinIO
MINIO_HOST=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=flowops-documents

# Security
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/flowops.log

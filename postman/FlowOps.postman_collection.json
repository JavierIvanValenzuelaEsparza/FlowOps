                "organizations"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('has organization id', () => pm.expect(body.data.id).to.be.a('string'));",
                  "if (body.data && body.data.id) {",

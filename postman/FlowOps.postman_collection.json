    {
      "name": "Documents",
      "item": [
        {
          "name": "Upload Document",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/v1/documents",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "documents"
              ]
            },
            "description": "Seleccionar manualmente un PDF/PNG/JPEG/TIFF en el campo 'file'. Requiere MinIO y RabbitMQ levantados (docker compose up): sube el archivo, crea el documento con status 'pending' y encola el job de OCR. Guarda document_id en el environment."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('document is pending OCR', () => {",
                  "    pm.expect(body.data.status).to.eql('pending');",
                  "});",
                  "if (body.data && body.data.id) {",
                  "    pm.environment.set('document_id', body.data.id);",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "List Documents (cursor pagination)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/documents?limit=20",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "documents"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "cursor",
                  "value": "",
                  "disabled": true
                },
                {
                  "key": "status",
                  "value": "completed",
                  "disabled": true
                }
              ]
            },
            "description": "Paginacion por cursor: usar el 'next_cursor' de la respuesta como parametro 'cursor' para la pagina siguiente."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('has items array', () => {",
                  "    pm.expect(pm.response.json().items).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Get Document (con texto OCR)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/documents/{{document_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "documents",
                "{{document_id}}"
              ]
            },
            "description": "Cuando el servicio OCR termina, status pasa a 'completed' y 'ocr_text' contiene el texto extraido."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const doc = pm.response.json().data;",
                  "console.log('status:', doc.status, '| pages:', doc.ocr_pages, '| confidence:', doc.ocr_confidence);"
                ]
              }
            }
          ],
          "response": []
        }
      ]
